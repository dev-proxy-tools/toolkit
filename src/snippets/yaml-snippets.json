  "PriceYaml": {
    "prefix": "devproxy-price",
    "body": [
      "gpt-4:",
      "  input: 0.03",
      "  output: 0.06"
    ],
    "description": "Dev Proxy price"
  },
  "RequestYaml": {
    "prefix": "devproxy-request",
    "body": [
      "- request:",
      "    url: $1",
      "  response: $2"
    ],
    "description": "Dev Proxy request"
  },
  "ResponseYaml": {
    "prefix": "devproxy-response",
    "body": [
      "- statusCode: ${1:400}",
      "  body: $2",
      "  headers:",
      "    - $3"
    ],
    "description": "Dev Proxy response"
  },
  "ResponseHeaderYaml": {
    "prefix": "devproxy-response-header",
    "body": [
      "- name: $1",
      "  value: $2"
    ],
    "description": "Dev Proxy response header"
  },
  "RewriteYaml": {
    "prefix": "devproxy-rewrite",
    "body": [
      "- in:",
      "    url: $1",
      "  out:",
      "    url: $2"
    ],
    "description": "Dev Proxy rewrite"
  },
  "AuthPluginYaml": {
    "prefix": "devproxy-plugin-auth",
    "body": [
      "- name: AuthPlugin",
      "  enabled: true",
      "  pluginPath: \"~appFolder/plugins/DevProxy.Plugins.dll\"",
      "  configSection: auth"
    ],
    "description": "AuthPlugin instance"
  },
  "AuthPluginAPIKeyConfigYaml": {
    "prefix": "devproxy-plugin-auth-config-apikey",
    "body": [
      "auth:",
      "  $schema: \"https://raw.githubusercontent.com/dotnet/dev-proxy/main/schemas/v2.1.0/authplugin.schema.json\"",
      "  type: apiKey",
      "  apiKey:",
      "    parameters:",
      "      - in: header",
      "        name: x-api-key",
      "      - in: query",
      "        name: code",
      "    allowedKeys:",
      "      - 1234"
    ],
    "description": "AuthPlugin API Key config section"
  },
  "AuthPluginOAuth2ConfigYaml": {
    "prefix": "devproxy-plugin-auth-config-oauth2",
    "body": [
      "auth:",
      "  $schema: \"https://raw.githubusercontent.com/dotnet/dev-proxy/main/schemas/v2.1.0/authplugin.schema.json\"",
      "  type: oauth2",
      "  oauth2:",
      "    metadataUrl: \"https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration\"",
      "    allowedApplications:",
      "      - 00000000-0000-0000-0000-000000000000",
      "    allowedAudiences:",
      "      - 00000000-0000-0000-0000-000000000000",
      "    allowedPrincipals:",
      "      - 00000000-0000-0000-0000-000000000000",
      "    allowedTenants:",
      "      - 00000000-0000-0000-0000-000000000000",
      "    issuer: \"https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0\"",
      "    scopes:",
      "      - Posts.Read",
      "    validateLifetime: true",
      "    validateSigningKey: true"
    ],
    "description": "AuthPlugin OAuth2 config section"
  },
