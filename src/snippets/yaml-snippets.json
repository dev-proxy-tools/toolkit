  "PricesFileYaml": {
    "prefix": "devproxy-prices-file",
    "body": [
      "$schema: \"https://raw.githubusercontent.com/dotnet/dev-proxy/main/schemas/v2.1.0/openaitelemetryplugin.pricesfile.schema.json\"",
